<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray">

    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/blue_confidence"
        android:layout_marginBottom="-15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/layoutTrabajador" />

    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="8dp"
        android:text="¡Hola! ¿Qué necesitas hoy?"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:elevation="5dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnIrAPerfil"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnIrAPerfil"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_edit"
        android:elevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <ImageButton
        android:id="@+id/btnVerMensajes"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginEnd="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_message_24"
        android:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="@id/btnIrAPerfil"
        app:layout_constraintEnd_toStartOf="@id/btnIrAPerfil"
        app:layout_constraintTop_toTopOf="@id/btnIrAPerfil"
        app:tint="@color/white" />

    <FrameLayout
        android:id="@+id/frameNotificaciones"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginEnd="6dp"
        android:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="@id/btnVerMensajes"
        app:layout_constraintEnd_toStartOf="@id/btnVerMensajes"
        app:layout_constraintTop_toTopOf="@id/btnVerMensajes">

        <ImageButton
            android:id="@+id/btnNotificaciones"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_popup_reminder"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvBadgeNotif"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="1dp"
            android:layout_marginEnd="1dp"
            android:background="@drawable/badge_background"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="8sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>

    <ImageButton
        android:id="@+id/btnAtencionCliente"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginEnd="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_dialog_email"
        android:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="@id/frameNotificaciones"
        app:layout_constraintEnd_toStartOf="@id/frameNotificaciones"
        app:layout_constraintTop_toTopOf="@id/frameNotificaciones"
        app:tint="@color/white" />

    <androidx.cardview.widget.CardView
        android:id="@+id/searchCard"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="25dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvGreeting">

        <AutoCompleteTextView
            android:id="@+id/etBuscarServicio"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:hint="Busca gasfiteros, limpieza..."
            android:paddingHorizontal="20dp"
            android:textSize="14sp"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:completionThreshold="1" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/layoutTrabajador"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:cardCornerRadius="15dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/searchCard"
        app:layout_goneMarginTop="12dp"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="15dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Modo Trabajador"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Desconectado" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="15dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/vpCarrusel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <LinearLayout
                        android:id="@+id/layoutIndicadores"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        android:gravity="center"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategorias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="10dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/btnVerMasCategorias"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:text="Ver más categorías"
                android:textColor="@color/blue_confidence"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTituloHistorial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Historial de servicios finalizados"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_margin="15dp"
                android:textColor="@color/black" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHistorialServicios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabFiltrosBandeja"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_gray"
        android:visibility="gone"
        android:elevation="10dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabSelectedTextColor="@color/blue_confidence"
        app:tabIndicatorColor="@color/blue_confidence"
        app:layout_constraintTop_toBottomOf="@id/headerBackground" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBandejaEntrada"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/background_gray"
        android:elevation="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabFiltrosBandeja" />

</androidx.constraintlayout.widget.ConstraintLayout>