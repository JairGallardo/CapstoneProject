<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:id="@+id/ivIconoEspera"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@android:drawable/ic_dialog_info"
        app:tint="@color/blue_confidence"
        android:layout_marginBottom="24dp" />

    <ProgressBar
        android:id="@+id/pbCargandoPago"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:indeterminateTint="@color/blue_confidence"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/tvTituloEspera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Esperando confirmación"
        android:textColor="@color/blue_confidence"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvMensajeEspera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="Estamos notificando al trabajador sobre tu pago. Por favor, no cierres esta pantalla."
        android:textColor="#666666"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvNombreTrabajadorEspera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Trabajador: Cargando..."
        android:textStyle="italic"
        android:textColor="@color/black" />

</LinearLayout>