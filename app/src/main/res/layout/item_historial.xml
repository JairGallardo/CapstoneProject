<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/background_card"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/green_lime"
            android:minHeight="60dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="13dp">

            <TextView
                android:id="@+id/tvHistorialCategoria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_green"
                android:paddingStart="9dp"
                android:paddingEnd="9dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:textSize="11sp"
                android:textColor="@color/green_dark"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                tools:text="Gasfitería" />

            <TextView
                android:id="@+id/tvHistorialNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                tools:text="Cliente: Carlos Mendoza" />

            <TextView
                android:id="@+id/tvHistorialFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                tools:text="12 jun 2025" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingEnd="16dp"
            android:paddingStart="8dp"
            android:minWidth="72dp">

            <TextView
                android:id="@+id/tvHistorialMonto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/green_primary"
                android:textStyle="bold"
                android:textSize="17sp"
                android:gravity="end"
                tools:text="S/ 120.00" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="pagado"
                android:textSize="10sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="1dp"
                android:gravity="end" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>