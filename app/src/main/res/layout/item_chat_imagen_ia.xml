<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="end"
    android:padding="4dp"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#1565C0">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:minWidth="180dp"
            android:maxWidth="260dp">

            <!-- Etiqueta IA -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Propuesta con IA"
                    android:textColor="#90CAF9"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <!-- Imagen original del cliente -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷 Foto original"
                android:textColor="#90CAF9"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="240dp"
                android:layout_height="160dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/ivImagenPropuesta"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery" />
            </androidx.cardview.widget.CardView>

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#3D6B9E"
                android:layout_marginVertical="8dp"/>

            <!-- Imagen editada por IA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ Así quedaría:"
                android:textColor="#90CAF9"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardImagenEditada"
                android:layout_width="240dp"
                android:layout_height="160dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/ivImagenEditada"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />
            </androidx.cardview.widget.CardView>

            <!-- Descripción del cliente -->
            <TextView
                android:id="@+id/tvDescripcionPropuesta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp"
                android:text="Descripción de la propuesta" />

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#3D6B9E"
                android:layout_marginVertical="8dp"/>

            <!-- Respuesta IA -->
            <TextView
                android:id="@+id/tvRespuestaIA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#BBDEFB"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp"
                android:fontFamily="sans-serif-light"
                android:text="Respuesta de la IA..." />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>