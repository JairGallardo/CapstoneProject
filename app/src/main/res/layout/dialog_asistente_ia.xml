<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white">

    <!-- Título -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✨ Asistente IA"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1565C0" />

        <TextView
            android:id="@+id/tvCategoriaIA"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pintura"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="#42A5F5"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp" />
    </LinearLayout>

    <!-- Preview de imagen -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="16dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/ivPreviewImagen"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery" />

            <!-- Overlay cuando no hay imagen -->
            <LinearLayout
                android:id="@+id/layoutSinImagen"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#F5F7F8">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📷"
                    android:textSize="36sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selecciona una foto"
                    android:textColor="#9E9E9E"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- Botones para seleccionar imagen -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnTomarFoto"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="📷 Cámara"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnElegirGaleria"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="🖼 Galería"
            android:textSize="13sp"
            android:backgroundTint="#42A5F5"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <!-- Campo de instrucción -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¿Cómo quieres que quede?"
        android:textStyle="bold"
        android:textColor="#212121"
        android:textSize="14sp"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etInstruccionIA"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: Pinta la pared de azul marino con textura mate, mantén la ventana..."
        android:background="@android:drawable/edit_text"
        android:padding="12dp"
        android:inputType="textMultiLine"
        android:lines="3"
        android:maxLines="5"
        android:gravity="top"
        android:textSize="14sp"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="La IA analizará tu foto y generará una propuesta detallada para el trabajador."
        android:textColor="#9E9E9E"
        android:textSize="12sp"
        android:layout_marginBottom="20dp" />

    <!-- Estado de carga -->
    <LinearLayout
        android:id="@+id/layoutCargandoIA"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="12dp">

        <ProgressBar
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:indeterminateTint="#1565C0" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analizando imagen..."
            android:textColor="#1565C0"
            android:textSize="14sp"
            android:layout_marginStart="10dp" />
    </LinearLayout>

    <!-- Botón generar -->
    <Button
        android:id="@+id/btnGenerarPropuestaIA"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="✨ GENERAR Y ENVIAR PROPUESTA"
        android:textSize="14sp"
        android:textStyle="bold"
        android:backgroundTint="#1565C0"
        android:textColor="@android:color/white" />

</LinearLayout>