<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_page"
    tools:context=".ui.negociacion.NegociacionActivity">

    <LinearLayout
        android:id="@+id/toolbarNegociacion"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/green_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/green_lime"
            app:strokeWidth="2dp"
            app:cardBackgroundColor="@color/green_surface">

            <ImageView
                android:id="@+id/ivFotoChat"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_camera" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tvNombreChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del Usuario"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvEspecialidadChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="En línea"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnEliminarChatCompleto"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            android:contentDescription="Eliminar chat"
            app:tint="@color/white" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatNegociacion"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/toolbarNegociacion"
        app:layout_constraintBottom_toTopOf="@id/btnIrAPagar" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnIrAPagar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PAGAR AHORA"
        android:textColor="@color/white"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:visibility="gone"
        android:layout_marginBottom="6dp"
        app:backgroundTint="@color/green_primary"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toTopOf="@id/layoutControlNegociacion"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinuarProceso"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CONTINUAR PROCESO"
        android:textColor="@color/white"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:visibility="gone"
        android:layout_marginBottom="6dp"
        app:backgroundTint="@color/green_primary"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toTopOf="@id/layoutControlNegociacion"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/layoutControlNegociacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:id="@+id/layoutOferta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etMontoOferta"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:hint="S/ Oferta"
                    android:inputType="numberDecimal"
                    android:background="@android:drawable/edit_text"
                    android:paddingHorizontal="15dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEnviarOferta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Ofertar"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/green_primary"
                    app:cornerRadius="10dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnAsistenteIA"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Asistente IA"
                    android:src="@android:drawable/ic_menu_camera"
                    android:visibility="gone"
                    app:tint="@color/green_primary" />

                <EditText
                    android:id="@+id/etMensajeChat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Escribe un mensaje..."
                    android:maxLines="3"
                    android:background="@null"
                    android:padding="10dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint" />

                <ImageButton
                    android:id="@+id/btnEnviarMensaje"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@android:drawable/ic_menu_send"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/green_primary" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>