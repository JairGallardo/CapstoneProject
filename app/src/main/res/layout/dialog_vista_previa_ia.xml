<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@android:color/white">

        <!-- Encabezado -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✨ Vista previa"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Revisa el resultado antes de enviarlo. Si no te convence, puedes pedir un cambio."
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="16dp" />

        <!-- Etiqueta imagen original -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📷 Tu foto original"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:layout_marginBottom="6dp" />

        <!-- Imagen original -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp"
            android:layout_marginBottom="14dp">

            <ImageView
                android:id="@+id/ivVistaPreviaOriginal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery" />

        </androidx.cardview.widget.CardView>

        <!-- Separador con flecha -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⬇  Resultado de la IA"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:layout_marginBottom="6dp" />

        <!-- Imagen editada por IA -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp"
            android:layout_marginBottom="14dp">

            <ImageView
                android:id="@+id/ivVistaPreviaEditada"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery" />

        </androidx.cardview.widget.CardView>

        <!-- Propuesta técnica -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🤖 Propuesta técnica generada"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvVistaPreviaPropuesta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F7F8"
            android:padding="12dp"
            android:textSize="13sp"
            android:textColor="#212121"
            android:layout_marginBottom="16dp" />

        <!-- Loading reintentar -->
        <LinearLayout
            android:id="@+id/layoutCargandoPreviaIA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="12dp">

            <ProgressBar
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:indeterminateTint="#1565C0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Generando nueva versión..."
                android:textColor="#1565C0"
                android:textSize="13sp"
                android:layout_marginStart="10dp" />
        </LinearLayout>

        <!-- Botón enviar -->
        <Button
            android:id="@+id/btnEnviarVistaPreviaIA"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="📤  Enviar al chat"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#1565C0"
            android:textColor="@android:color/white"
            android:layout_marginBottom="10dp" />

        <!-- Botón "No me convence, cambiar algo" -->
        <Button
            android:id="@+id/btnMostrarReintentar"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="🔁  No me convence, quiero cambiar algo"
            android:textSize="13sp"
            android:backgroundTint="#E3F2FD"
            android:textColor="#1565C0"
            android:layout_marginBottom="10dp" />

        <!-- Campo de nueva instrucción (oculto hasta presionar el botón anterior) -->
        <LinearLayout
            android:id="@+id/layoutNuevaInstruccion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿Qué deseas cambiar?"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#424242"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etNuevaInstruccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ej: ponlo de color verde en vez de azul, también quita la mancha del techo..."
                android:background="@android:drawable/edit_text"
                android:padding="12dp"
                android:inputType="textMultiLine"
                android:lines="3"
                android:maxLines="5"
                android:gravity="top"
                android:textSize="13sp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnReintentarIA"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:text="✨  Generar nueva versión"
                android:textSize="13sp"
                android:backgroundTint="#42A5F5"
                android:textColor="@android:color/white" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>