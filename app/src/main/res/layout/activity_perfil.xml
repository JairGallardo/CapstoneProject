<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="150dp"
                android:layout_height="150dp"
                app:cardCornerRadius="75dp"
                app:cardElevation="4dp">
                <ImageView
                    android:id="@+id/ivPerfilFoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_camera" />
            </androidx.cardview.widget.CardView>

            <ImageButton
                android:id="@+id/btnCambiarFoto"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/circle_background_blue"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="@color/white"
                android:elevation="6dp" />
        </FrameLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/headerDatosPersonales"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▼ Datos Personales"
                    android:padding="16dp"
                    android:textStyle="bold"
                    android:background="#E1E8F0"/>

                <LinearLayout
                    android:id="@+id/containerDatosPersonales"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre:"
                        android:textStyle="bold"
                        android:textColor="@color/black"/>
                    <EditText
                        android:id="@+id/etPerfilNombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nombre completo"
                        android:background="@null"
                        android:paddingTop="4dp"
                        android:paddingBottom="12dp"
                        android:textColor="@color/black"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Correo electrónico:"
                        android:textStyle="bold"
                        android:textColor="@color/black"/>
                    <TextView
                        android:id="@+id/tvPerfilCorreo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="4dp"
                        android:paddingBottom="12dp"
                        android:text="correo@ejemplo.com"
                        android:textColor="#555555"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Teléfono de contacto:"
                        android:textStyle="bold"
                        android:textColor="@color/black"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <EditText
                            android:id="@+id/etPerfilTelefono"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Número de celular"
                            android:inputType="phone"
                            android:background="@null"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:textColor="@color/black"/>

                        <ImageButton
                            android:id="@+id/btnLlamarTrabajador"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:drawable/ic_menu_call"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="@color/blue_confidence"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <Button android:id="@+id/btnCambiarPass" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cambiar Contraseña" android:layout_marginTop="8dp" style="@style/Widget.MaterialComponents.Button.TextButton"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPortafolio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/headerPortafolio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▶ Mi Portafolio"
                    android:padding="16dp"
                    android:textStyle="bold"/>
                <LinearLayout
                    android:id="@+id/containerPortafolio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <Button android:id="@+id/btnSubirFotoPortafolio" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="+ Agregar foto al portafolio"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvPortafolio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="100dp"
                        android:layout_marginTop="8dp"/>

                    <LinearLayout
                        android:id="@+id/layoutDescripcionCategoriaLectura"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp"
                        android:visibility="gone">
                        <TextView
                            android:id="@+id/tvTituloDescCategoria"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Descripción de la Especialidad:"
                            android:textStyle="bold"
                            android:textColor="@color/black"/>
                        <TextView
                            android:id="@+id/tvContenidoDescCategoria"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Sin descripción para esta especialidad."
                            android:textColor="#333333"
                            android:textSize="15sp"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnSeleccionarCategorias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Especialidades"
                        android:layout_marginTop="12dp"/>

                    <LinearLayout
                        android:id="@+id/containerEspecialidades"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:background="#F0F4F8"
                        android:padding="8dp"
                        android:layout_marginTop="8dp">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvEspecialidadesOculto"
                            android:layout_width="match_parent"
                            android:layout_height="250dp"
                            android:background="#FFFFFF" />

                        <Button
                            android:id="@+id/btnHechoEspecialidades"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Guardar Especialidades"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardMetodoPago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/headerPago"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▶ Método de Cobro (Yape/Plin)"
                    android:padding="16dp"
                    android:textStyle="bold"/>
                <LinearLayout
                    android:id="@+id/containerPago"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:visibility="gone">
                    <RadioGroup android:id="@+id/rgTipoQR" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center">
                        <RadioButton android:id="@+id/rbYapePerfil" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Yape" android:checked="true"/>
                        <RadioButton android:id="@+id/rbPlinPerfil" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Plin" android:layout_marginStart="20dp"/>
                    </RadioGroup>
                    <ImageView android:id="@+id/ivQrActual" android:layout_width="200dp" android:layout_height="200dp" android:src="@android:drawable/ic_menu_gallery" android:layout_marginTop="10dp" android:scaleType="fitCenter"/>
                    <Button android:id="@+id/btnActualizarQR" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="CAMBIAR IMAGEN QR" android:layout_marginTop="12dp" android:backgroundTint="@color/blue_confidence"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardCalificaciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/headerCalificaciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▶ Calificaciones y Reseñas"
                    android:padding="16dp"
                    android:textStyle="bold"/>
                <LinearLayout
                    android:id="@+id/containerCalificaciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvCalificaciones"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:minHeight="50dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button android:id="@+id/btnGuardarCambios" android:layout_width="match_parent" android:layout_height="55dp" android:text="GUARDAR TODO" android:layout_marginTop="20dp" android:backgroundTint="@color/blue_confidence" android:textColor="@color/white"/>
        <Button android:id="@+id/btnCerrarSesion" android:layout_width="match_parent" android:layout_height="55dp" android:text="Cerrar Sesión" android:layout_marginTop="8dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    </LinearLayout>
</ScrollView>