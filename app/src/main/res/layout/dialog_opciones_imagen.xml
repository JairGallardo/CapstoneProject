<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Imagen lista"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:layout_marginBottom="14dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="220dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/ivPreviewOpciones"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery" />

    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¿Qué deseas hacer con esta imagen?"
        android:textSize="14sp"
        android:textColor="#424242"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Puedes enviarla tal como está, o dejar que la IA la mejore visualmente y genere una propuesta técnica."
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        android:layout_marginBottom="8dp" />

</LinearLayout>