<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="DominGO" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_dark</item>
        <item name="colorSecondary">@color/green_lime</item>
        <item name="colorSecondaryVariant">@color/green_medium</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorControlActivated">@color/green_primary</item>
        <item name="colorControlHighlight">@color/green_surface</item>

        <item name="rippleColor">@color/green_surface</item>

        <item name="android:windowBackground">@color/background_page</item>
        <item name="colorSurface">@color/background_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <item name="android:statusBarColor">@color/green_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>

    <style name="DominGO.Header">
        <item name="android:background">@drawable/bg_header_green</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">20dp</item>
        <item name="android:elevation">4dp</item>
    </style>

    <style name="DominGO.Header.Title">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="DominGO.Header.Subtitle">
        <item name="android:textColor">#CCFFFFFF</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="DominGO.Header.IconButton">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:background">@drawable/bg_icon_button_header</item>
        <item name="tint">@color/white</item>
    </style>

    <style name="DominGO.Card">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">3dp</item>
        <item name="cardBackgroundColor">@color/background_card</item>
        <item name="android:layout_marginBottom">10dp</item>
    </style>

    <style name="DominGO.Category" />

    <style name="DominGO.Card.Category">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">6dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/background_card</item>
    </style>

    <style name="DominGO.Category.Icon">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:background">@drawable/bg_category_icon</item>
        <item name="android:padding">10dp</item>
        <item name="tint">@color/green_primary</item>
    </style>

    <style name="DominGO.Category.Text">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="DominGO.Button" parent="Widget.MaterialComponents.Button" />

    <style name="DominGO.Button.Primary">
        <item name="android:layout_height">48dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/green_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="elevation">2dp</item>
    </style>

    <style name="DominGO.Button.Secondary">
        <item name="android:layout_height">44dp</item>
        <item name="android:textColor">@color/green_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="strokeColor">@color/green_primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="DominGO.SectionTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">20dp</item>
        <item name="android:paddingBottom">10dp</item>
    </style>

    <style name="DominGO.TextLink">
        <item name="android:textColor">@color/green_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">10dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <style name="CategoryCardStyle" parent="DominGO.Card.Category"/>

    <style name="CategoryContainerStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">10dp</item>
    </style>

    <style name="CategoryIconStyle" parent="DominGO.Category.Icon"/>
    <style name="CategoryTextStyle" parent="DominGO.Category.Text"/>

</resources>