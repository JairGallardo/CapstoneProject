<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.DominGO" parent="Theme.Material3.DayNight.NoActionBar">
    </style>

    <style name="Theme.DominGO" parent="Base.Theme.DominGO" />

    <style name="CategoryCardStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">120dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">8dp</item>
        <item name="cardCornerRadius">15dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <style name="CategoryContainerStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="CategoryIconStyle">
        <item name="android:layout_width">45dp</item>
        <item name="android:layout_height">45dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:tint">@color/blue_confidence</item>
    </style>

    <style name="CategoryTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_dark</item>
    </style>
</resources>